<?xml version="1.0"?>
<robot name="guitar">

  <!-- Base link (body mesh, no collision) -->
  <link name="base">
    <visual>
      <geometry><mesh filename="meshes/body.stl"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
  </link>

  <!-- Neck (no collision) -->
  <link name="neck">
    <visual>
      <origin xyz="0.0308 -0.14885 0.005106" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/neck.stl"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>
  <joint name="neck_joint" type="fixed">
    <parent link="base"/>
    <child link="neck"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- String 1 -->
  <link name="string1">
    <collision>
      <origin xyz="0.37455 -0.465 0.04" rpy="1.5708 1.5708 0"/>
      <geometry><cylinder radius="0.001" length="0.656"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.37455 -0.465 0.04" rpy="1.5708 1.5708 0"/>
      <geometry><cylinder radius="0.001" length="0.656"/></geometry>
      <material name="s1"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>
  <joint name="string1_joint" type="fixed">
    <parent link="base"/>
    <child link="string1"/>
    <origin xyz="0 0 0"/>
  </joint>

